# Copy this file to .env.prod and run:
#   docker compose --env-file .env.prod up -d
#
# Use URL-safe secret values for database, Redis, and ClickHouse passwords
# because docker-compose.yml builds DSNs from these variables.

COMPOSE_PROJECT_NAME=flintbase
FLINTBASE_IMAGE=ghcr.io/flintbasedev/app:nightly
FLINTBASE_HTTP_BIND=0.0.0.0
FLINTBASE_HTTP_PORT=23322

TZ=UTC
NODE_NAME=flintbase-prod-1

SESSION_SECRET=replace-with-a-long-random-session-secret
CRYPTO_SECRET=replace-with-a-long-random-crypto-secret

POSTGRES_USER=flintbase
POSTGRES_PASSWORD=replace_with_url_safe_postgres_password
POSTGRES_DB=flintbase

REDIS_PASSWORD=replace_with_url_safe_redis_password

CLICKHOUSE_USER=flintbase_logs
CLICKHOUSE_PASSWORD=replace_with_url_safe_clickhouse_password
CLICKHOUSE_DB=flintbase_logs

WORKOS_API_KEY=sk_live_replace_me
WORKOS_CLIENT_ID=client_replace_me
WORKOS_REDIRECT_URI=https://app.example.com/api/workos/callback
WORKOS_ROOT_EMAILS=admin@example.com
WORKOS_ROOT_USER_IDS=
WORKOS_API_BASE_URL=https://api.workos.com

ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
BATCH_UPDATE_INTERVAL=5
SYNC_FREQUENCY=60
MIGRATION_TIMEOUT=300
